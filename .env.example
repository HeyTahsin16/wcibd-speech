# ── Discord ────────────────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# ── GitHub content repo ────────────────────────────────────────────────────────
# The GitHub repo that holds your images/ folder and data/responses.json
GITHUB_OWNER=your_github_username
GITHUB_REPO=wcibd-content
GITHUB_BRANCH=main

# Optional: GitHub Personal Access Token (recommended)
# Without it you get 60 API requests/hour; with it you get 5000/hr
# Create one at https://github.com/settings/tokens  (only needs "repo" read scope)
GITHUB_TOKEN=

# ── Folder/file paths inside the GitHub repo ──────────────────────────────────
IMAGES_FOLDER=images
RESPONSES_PATH=data/responses.json

# ── Cache TTL ─────────────────────────────────────────────────────────────────
# How long (in seconds) to cache the image list and responses before re-fetching
# 300 = 5 minutes. Lower = fresher data, more GitHub API calls.
CACHE_TTL=300
